    {
      "parameters": {
        "jsCode": "// === Processa entradas do formulário e dados do clima ===\nconst formData = $('📝 Formulário - Humor & Cidade').item.json;\nconst geoData  = $('🌍 Buscar Coordenadas (Geocoding)').item.json;\nconst weatherData = $input.item.json;\n\nconst humor = formData['Qual é o seu humor agora?'];\nconst cidadeInformada = formData['Em qual cidade você está?'];\n\n// Validação: cidade encontrada e temperatura disponível?\nconst sucesso = (geoData.results && geoData.results.length > 0 && weatherData.current && typeof weatherData.current.temperature_2m === 'number');\n\nlet cidadeOficial = null;\nlet pais = null;\nlet estado = null;\nlet temperatura = null;\nlet weatherCode = null;\nlet precipitacao = null;\nlet umidade = null;\nlet vento = null;\nlet descricaoClima = 'Dados indisponíveis';\n\nif (sucesso) {\n  cidadeOficial = geoData.results[0].name;\n  pais   = geoData.results[0].country  || '';\n  estado = geoData.results[0].admin1   || '';\n\n  // Dados climáticos atuais\n  const current = weatherData.current || {};\n  temperatura  = current.temperature_2m;\n  weatherCode  = current.weather_code;\n  precipitacao = current.precipitation;\n  umidade      = current.relative_humidity_2m;\n  vento        = current.wind_speed_10m;\n\n  // Mapeamento dos códigos da Open-Meteo (WMO Weather codes)\n  const weatherDescriptions = {\n    0: 'Céu limpo ☀️', 1: 'Predominantemente ensolarado 🌤️', 2: 'Parcialmente nublado ⛅', 3: 'Nublado ☁️',\n    45: 'Neblina 🌫️', 48: 'Neblina com geada 🌫️❄️', 51: 'Garoa fraca 🌦️', 53: 'Garoa moderada 🌦️',\n    55: 'Garoa intensa 🌧️', 61: 'Chuva fraca 🌧️', 63: 'Chuva moderada 🌧️', 65: 'Chuva forte ⛈️',\n    71: 'Neve fraca 🌨️', 73: 'Neve moderada 🌨️', 75: 'Neve forte ❄️', 80: 'Pancadas de chuva fracas 🌦️',\n    81: 'Pancadas de chuva moderadas 🌧️', 82: 'Pancadas de chuva fortes ⛈️', 95: 'Trovoada ⛈️',\n    96: 'Trovoada com granizo ⛈️', 99: 'Trovoada com granizo forte ⛈️'\n  };\n  descricaoClima = weatherDescriptions[weatherCode] || 'Condição desconhecida';\n}\n\nreturn [{\n  json: {\n    sucesso, // Nova variável booleana para indicar sucesso na busca\n    humor,\n    cidadeInformada,\n    cidadeOficial,\n    estado,\n    pais,\n    temperatura,\n    weatherCode,\n    descricaoClima,\n    precipitacao,\n    umidade,\n    vento\n  }\n}];"
      },
